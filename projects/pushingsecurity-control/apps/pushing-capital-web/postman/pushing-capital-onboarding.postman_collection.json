{
  "info": {
    "name": "Pushing Capital Onboarding",
    "_postman_id": "8fe5b920-42b5-4d34-9157-aac2667236e3",
    "description": "End-to-end helpers for license parsing, onboarding submission, platform contact upsert, and DocuSign webhook replay.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "localBaseUrl",
      "value": "http://localhost:3100"
    },
    {
      "key": "platformBaseUrl",
      "value": "https://platform.pushingcap.com"
    },
    {
      "key": "webhookBaseUrl",
      "value": "https://webhooks.pushingcap.com"
    },
    {
      "key": "platformBearerToken",
      "value": ""
    },
    {
      "key": "applicantFirstName",
      "value": "Alex"
    },
    {
      "key": "applicantMiddleName",
      "value": "Taylor"
    },
    {
      "key": "applicantLastName",
      "value": "Morgan"
    },
    {
      "key": "applicantPhone",
      "value": "5551112222"
    },
    {
      "key": "applicantEmail",
      "value": "alex.morgan@example.com"
    },
    {
      "key": "lastLicenseParse",
      "value": "null"
    },
    {
      "key": "lastOnboardingJobId",
      "value": ""
    },
    {
      "key": "lastPlatformContactId",
      "value": ""
    },
    {
      "key": "lastDocuSignEnvelopeId",
      "value": ""
    },
    {
      "key": "lastDocuSignTemplateId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Parse Driver License",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const payload = pm.response.json();",
              "if (payload.licenseParse) {",
              "  pm.collectionVariables.set('lastLicenseParse', JSON.stringify(payload.licenseParse));",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{localBaseUrl}}/api/document-ai/parse-license",
          "host": [
            "{{localBaseUrl}}"
          ],
          "path": [
            "api",
            "document-ai",
            "parse-license"
          ]
        },
        "description": "Uploads a driver-license image and stores the parsed JSON into the collection variable `lastLicenseParse`."
      },
      "response": []
    },
    {
      "name": "Submit Onboarding",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('lastLicenseParse')) {",
              "  pm.collectionVariables.set('lastLicenseParse', 'null');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const payload = pm.response.json();",
              "if (payload.job?.id) {",
              "  pm.collectionVariables.set('lastOnboardingJobId', payload.job.id);",
              "}",
              "if (payload.contactSync?.externalId) {",
              "  pm.collectionVariables.set('lastPlatformContactId', payload.contactSync.externalId);",
              "}",
              "if (payload.docuSignEnvelope?.envelopeId) {",
              "  pm.collectionVariables.set('lastDocuSignEnvelopeId', payload.docuSignEnvelope.envelopeId);",
              "}",
              "if (payload.docuSignEnvelope?.templateId) {",
              "  pm.collectionVariables.set('lastDocuSignTemplateId', payload.docuSignEnvelope.templateId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"{{applicantFirstName}}\",\n  \"lastName\": \"{{applicantLastName}}\",\n  \"phone\": \"{{applicantPhone}}\",\n  \"email\": \"{{applicantEmail}}\",\n  \"website\": \"\",\n  \"metadata\": {\n    \"pageUrl\": \"{{localBaseUrl}}/onboard\",\n    \"pagePath\": \"/onboard\",\n    \"referrer\": null,\n    \"browserLanguage\": \"en-US\",\n    \"browserTimeZone\": \"America/Los_Angeles\",\n    \"screenWidth\": 1440,\n    \"screenHeight\": 900,\n    \"viewportWidth\": 1440,\n    \"viewportHeight\": 900,\n    \"utmSource\": \"postman\",\n    \"utmMedium\": \"manual-test\",\n    \"utmCampaign\": \"onboarding-debug\",\n    \"utmTerm\": null,\n    \"utmContent\": null,\n    \"gclid\": null,\n    \"fbclid\": null\n  },\n  \"licenseParse\": {{lastLicenseParse}}\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{localBaseUrl}}/api/onboarding",
          "host": [
            "{{localBaseUrl}}"
          ],
          "path": [
            "api",
            "onboarding"
          ]
        },
        "description": "Creates the onboarding job, syncs the enriched contact into the platform, mirrors the job to the webhook hub, and sends the Mutual NDA."
      },
      "response": []
    },
    {
      "name": "Upsert Contact (Legal Identity + DocuSign)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{platformBearerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{applicantEmail}}\",\n  \"firstname\": \"{{applicantFirstName}}\",\n  \"middlename\": \"{{applicantMiddleName}}\",\n  \"lastname\": \"{{applicantLastName}}\",\n  \"phone\": \"{{applicantPhone}}\",\n  \"company\": \"Pushing Capital LLC\",\n  \"role\": \"lead\",\n  \"fullname\": \"{{applicantFirstName}} {{applicantMiddleName}} {{applicantLastName}}\",\n  \"legalfirstname\": \"{{applicantFirstName}}\",\n  \"legalmiddlename\": \"{{applicantMiddleName}}\",\n  \"legallastname\": \"{{applicantLastName}}\",\n  \"driverslicensenumber\": \"X1234567\",\n  \"driverlicensestate\": \"CA\",\n  \"dateofbirth\": \"01/15/1995\",\n  \"onboardingjobid\": \"{{lastOnboardingJobId}}\",\n  \"docusignenvelopeid\": \"{{lastDocuSignEnvelopeId}}\",\n  \"docusigntemplateid\": \"{{lastDocuSignTemplateId}}\",\n  \"metadata\": {\n    \"source\": \"postman-manual-upsert\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{platformBaseUrl}}/integrations/chat/contacts/upsert",
          "host": [
            "{{platformBaseUrl}}"
          ],
          "path": [
            "integrations",
            "chat",
            "contacts",
            "upsert"
          ]
        },
        "description": "Direct platform contact write for contact-schema validation and backfill."
      },
      "response": []
    },
    {
      "name": "Replay DocuSign Webhook",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"recipient-completed\",\n  \"data\": {\n    \"accountId\": \"5cc87900-690c-4fd2-b59c-125b5ec4ccf2\",\n    \"envelopeId\": \"{{lastDocuSignEnvelopeId}}\",\n    \"envelopeSummary\": {\n      \"status\": \"completed\",\n      \"customFields\": {\n        \"textCustomFields\": [\n          {\n            \"name\": \"onboardingJobId\",\n            \"value\": \"{{lastOnboardingJobId}}\"\n          },\n          {\n            \"name\": \"jobId\",\n            \"value\": \"{{lastOnboardingJobId}}\"\n          },\n          {\n            \"name\": \"platformContactId\",\n            \"value\": \"{{lastPlatformContactId}}\"\n          }\n        ]\n      },\n      \"recipients\": {\n        \"signers\": [\n          {\n            \"roleName\": \"Client\",\n            \"name\": \"{{applicantFirstName}} {{applicantLastName}}\",\n            \"email\": \"{{applicantEmail}}\",\n            \"status\": \"completed\"\n          }\n        ]\n      }\n    }\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{webhookBaseUrl}}/webhook/docusign",
          "host": [
            "{{webhookBaseUrl}}"
          ],
          "path": [
            "webhook",
            "docusign"
          ]
        },
        "description": "Manual webhook replay helper for the Cloudflare DocuSign receiver."
      },
      "response": []
    }
  ]
}
